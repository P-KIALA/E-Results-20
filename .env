# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=
PING_MESSAGE=

# Twilio credentials for local dev (set by admin)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_STATUS_CALLBACK_URL=

# WhatsApp template Content SID (set by admin)
WHATSAPP_TEMPLATE_CONTENT_SID=

# Optional: WhatsApp Business Account & API Key SID
TWILIO_WABA_ID=
TWILIO_API_KEY=


